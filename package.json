{
  "name": "@c8y/mcp-example",
  "version": "1.0.1",
  "description": "",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "extract-openapi": "start-server-and-test \"start:dev\" \"http-get://localhost:3000/health\" \"download-openapi\"",
    "download-openapi": "curl -o ./openapi.json http://localhost:3000/api-json && curl -o ./openapi.yaml http://localhost:3000/api-yaml",
    "docker:build": "docker buildx build --squash --progress=plain -t mcp-example --target=production -f ./Dockerfile .  && mkdir -p dist && docker save mcp-example > dist/image.tar && yarn zip:mcp-example",
    "zip:mcp-example": "cp ./manifest.json ./dist/cumulocity.json && cd dist && zip mcp-example.zip cumulocity.json image.tar"
  },
  "dependencies": {
    "@c8y/client": "1022.9.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@readme/openapi-parser": "^4.0.0",
    "@rekog/mcp-nest": "1.5.2",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "cache-manager": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "lodash": "^4.17.21",
    "oas-normalize": "^14.0.0",
    "ollama-ai-provider": "^1.2.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.8",
    "@nestjs/testing": "^11.1.6",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.5.12",
    "jest": "^30.0.5",
    "prettier": "^3.3.3",
    "semantic-release": "^25.0.0",
    "source-map-support": "^0.5.21",
    "start-server-and-test": "^2.0.12",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
